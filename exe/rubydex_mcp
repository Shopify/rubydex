#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))

require "rubydex/mcp_server_bridge"

binary = Rubydex::MCPServerBridge.binary_path

unless File.executable?(binary)
  abort(<<~MESSAGE.chomp)
    rubydex_mcp is not available at #{binary}.
    Install a precompiled rubydex gem, or reinstall rubydex with Cargo available so the MCP executable can be built locally.
  MESSAGE
end

args = if Rubydex::MCPServerBridge.passthrough?(ARGV)
  ARGV
elsif Rubydex::MCPServerBridge.setup_bundler_context(ARGV.first || Dir.pwd)
  # The wrapper only discovers paths that require Ruby/Bundler context. Rust still performs the indexing pass.
  Rubydex::MCPServerBridge.compute_index_paths(ARGV)
else
  ARGV.empty? ? [Dir.pwd] : ARGV
end

exec(binary, *args)
